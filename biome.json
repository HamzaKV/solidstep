{
    "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
    "vcs": {
        "enabled": false,
        "clientKind": "git",
        "useIgnoreFile": false
    },
    "files": {
        "ignoreUnknown": false,
        "includes": [
            "**",
            "!**/.*.js",
            "!**/node_modules/**",
            "!**/dist/**",
            "!**/build/**",
            "!**/out/**",
            "!**/.next/**",
            "!**/.output/**",
            "!**/.vinxi/**",
            "!**/coverage/**",
            "!**/.history/**",
            "!**/.opencode/**",
            "!**/.sisyphus/**",
            "!**/*.json",
            "!**/payload-types.ts",
            "!**/solidstep-env.d.ts",
            "!**/*.css"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4
    },
    "assist": { "actions": { "source": { "organizeImports": "off" } } },
    "linter": {
        "enabled": true,
        "rules": {
            "preset": "recommended",
            "style": {
                "useSelfClosingElements": "off",
                "noNonNullAssertion": "off",
                "useExponentiationOperator": "off"
            },
            "suspicious": {
                "noExplicitAny": "off",
                "noArrayIndexKey": "info",
                "noFallthroughSwitchClause": "warn",
                "noAssignInExpressions": "warn"
            },
            "a11y": {
                "useKeyWithClickEvents": "info",
                "noSvgWithoutTitle": "info",
                "noLabelWithoutControl": "info",
                "useAltText": "warn",
                "useMediaCaption": "info",
                "useValidAnchor": "warn"
            },
            "correctness": {
                "useExhaustiveDependencies": "warn"
            },
            "complexity": {
                "noForEach": "warn"
            }
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "jsxQuoteStyle": "single",
            "bracketSpacing": true,
            "semicolons": "always"
        }
    }
}
