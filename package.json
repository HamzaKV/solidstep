{
  "name": "solidstep-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Next Solid Step towards a more performant web",
  "type": "module",
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "lint": "biome ci .",
    "format": "biome format --write .",
    "typecheck": "pnpm --filter solidstep exec tsc --noEmit && pnpm --filter @varlabs/create-solidstep exec tsc --noEmit",
    "test": "pnpm --filter solidstep test && pnpm --filter @varlabs/create-solidstep test",
    "test:coverage": "pnpm --filter solidstep test:coverage",
    "test:e2e": "pnpm --filter kitchen-sink test:e2e",
    "build": "pnpm --filter \"./packages/*\" build",
    "bench": "node scripts/bench.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "bash scripts/release.sh",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@biomejs/biome": "^2.5.4",
    "@varlabs/monorun": "^0.1.4"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "lefthook": "^2.1.10"
  },
  "pnpm": {
    "overrides": {
      "h3": "1.15.11"
    }
  }
}
