{
    "name": "kitchen-sink",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "description": "Comprehensive SolidStep example app used for end-to-end testing.",
    "scripts": {
        "dev": "vinxi dev",
        "build": "vinxi build",
        "start": "vinxi start",
        "build:framework": "pnpm --filter solidstep build",
        "pretest:e2e": "pnpm run build:framework && pnpm run build",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui"
    },
    "dependencies": {
        "solid-js": "^1.9.14",
        "solidstep": "link:../../packages/solidstep/dist",
        "vinxi": "^0.5.11"
    },
    "devDependencies": {
        "@playwright/test": "^1.48.0",
        "typescript": "^5.8.3"
    }
}
