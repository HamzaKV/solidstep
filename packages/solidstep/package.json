{
    "name": "solidstep",
    "version": "1.1.0",
    "description": "Next Step SolidJS Framework for building web applications.",
    "type": "module",
    "author": "HamzaKV <hamzakv333@gmail.com>",
    "repository": {
        "type": "git",
        "url": "https://github.com/HamzaKV/solidstep.git"
    },
    "license": "MIT",
    "exports": {
        ".": {
            "types": "./index.d.ts",
            "default": "./index.js"
        },
        "./hooks/action-state": {
            "types": "./utils/hooks/action-state.d.ts",
            "default": "./utils/hooks/action-state.js"
        },
        "./client-only": {
            "types": "./utils/components/client-only.d.ts",
            "default": "./utils/components/client-only.js"
        },
        "./form": {
            "types": "./utils/components/form.d.ts",
            "default": "./utils/components/form.js"
        },
        "./hooks/form-status": {
            "types": "./utils/hooks/form-status.d.ts",
            "default": "./utils/hooks/form-status.js"
        },
        "./link": {
            "types": "./utils/components/link.d.ts",
            "default": "./utils/components/link.js"
        },
        "./router": {
            "types": "./utils/router-context.d.ts",
            "default": "./utils/router-context.js"
        },
        "./utils/action-schema": {
            "types": "./utils/action-schema.d.ts",
            "default": "./utils/action-schema.js"
        },
        "./utils/cache": {
            "types": "./utils/cache.d.ts",
            "default": "./utils/cache.js"
        },
        "./utils/cache-store": {
            "types": "./utils/cache-store.d.ts",
            "default": "./utils/cache-store.js"
        },
        "./utils/body-limit": {
            "types": "./utils/body-limit.d.ts",
            "default": "./utils/body-limit.js"
        },
        "./utils/client-only": {
            "types": "./utils/client-only.d.ts",
            "default": "./utils/client-only.js"
        },
        "./utils/cookies": {
            "types": "./utils/cookies.d.ts",
            "default": "./utils/cookies.js"
        },
        "./utils/cors": {
            "types": "./utils/cors.d.ts",
            "default": "./utils/cors.js"
        },
        "./utils/csp": {
            "types": "./utils/csp.d.ts",
            "default": "./utils/csp.js"
        },
        "./utils/csrf": {
            "types": "./utils/csrf.d.ts",
            "default": "./utils/csrf.js"
        },
        "./utils/error-handler": {
            "types": "./utils/error-handler.d.ts",
            "default": "./utils/error-handler.js"
        },
        "./utils/fetch.client": {
            "types": "./utils/fetch.client.d.ts",
            "default": "./utils/fetch.client.js"
        },
        "./utils/fetch.server": {
            "types": "./utils/fetch.server.d.ts",
            "default": "./utils/fetch.server.js"
        },
        "./utils/instrumentation": {
            "types": "./utils/instrumentation.d.ts",
            "default": "./utils/instrumentation.js"
        },
        "./utils/loader": {
            "types": "./utils/loader.d.ts",
            "default": "./utils/loader.js"
        },
        "./utils/loader-timeout": {
            "types": "./utils/loader-timeout.d.ts",
            "default": "./utils/loader-timeout.js"
        },
        "./utils/logger": {
            "types": "./utils/logger.d.ts",
            "default": "./utils/logger.js"
        },
        "./utils/meta": {
            "types": "./utils/meta.d.ts",
            "default": "./utils/meta.js"
        },
        "./utils/metadata": {
            "types": "./utils/metadata.d.ts",
            "default": "./utils/metadata.js"
        },
        "./utils/metrics": {
            "types": "./utils/metrics.d.ts",
            "default": "./utils/metrics.js"
        },
        "./utils/middleware": {
            "types": "./utils/middleware.d.ts",
            "default": "./utils/middleware.js"
        },
        "./utils/options": {
            "types": "./utils/options.d.ts",
            "default": "./utils/options.js"
        },
        "./utils/prerender": {
            "types": "./utils/prerender.d.ts",
            "default": "./utils/prerender.js"
        },
        "./utils/preview": {
            "types": "./utils/preview.d.ts",
            "default": "./utils/preview.js"
        },
        "./utils/rate-limit": {
            "types": "./utils/rate-limit.d.ts",
            "default": "./utils/rate-limit.js"
        },
        "./utils/redirect": {
            "types": "./utils/redirect.d.ts",
            "default": "./utils/redirect.js"
        },
        "./utils/server-only": {
            "types": "./utils/server-only.d.ts",
            "default": "./utils/server-only.js"
        },
        "./utils/sse": {
            "types": "./utils/sse.d.ts",
            "default": "./utils/sse.js"
        }
    },
    "scripts": {
        "clean": "rimraf ./dist",
        "copy-files:root": "copyfiles -u 0 README.md package.json LICENSE CHANGELOG.md ./dist",
        "build": "pnpm clean && tsc && pnpm copy-files:root",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest",
        "test:local": "pnpm build && cd ./dist && pnpm link --global",
        "test:local:clean": "pnpm unlink && pnpm clean",
        "roll": "pnpm build && cd dist && npm publish"
    },
    "keywords": [
        "solidjs",
        "web-development",
        "typescript",
        "npm",
        "solidstep",
        "framework"
    ],
    "dependencies": {
        "@standard-schema/spec": "^1.1.0",
        "@vinxi/server-functions": "0.5.1",
        "pino": "^10.3.1",
        "seroval": "^1.5.6",
        "seroval-plugins": "^1.5.6",
        "undici": "^8.7.0",
        "vite-plugin-solid": "^2.11.13"
    },
    "devDependencies": {
        "@solidjs/testing-library": "^0.8.10",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@vitest/coverage-v8": "^4.1.10",
        "copyfiles": "^2.4.1",
        "jsdom": "^29.1.1",
        "rimraf": "^6.1.3",
        "solid-js": "^1.9.14",
        "typescript": "^6.0.3",
        "vinxi": "0.5.8",
        "vitest": "^4.1.10",
        "zod": "^4.4.3"
    },
    "peerDependencies": {
        "solid-js": "^1.9.14",
        "vinxi": "^0.5.8"
    },
    "engines": {
        "node": ">=22.19.0"
    },
    "publishConfig": {
        "access": "public"
    }
}
